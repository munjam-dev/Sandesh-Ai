# =========================================
# Sandesh AI Environment Variables
# =========================================

# 1. Supabase (Database & Auth)
NEXT_PUBLIC_SUPABASE_URL=your_supabase_url
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key

# 2. OpenAI
OPENAI_API_KEY=sk-proj-your-openai-api-key

# 3. Google Workspace / Gmail API
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret
GOOGLE_REDIRECT_URI=http://localhost:3000/api/auth/gmail/callback

# 4. Meta / WhatsApp Cloud API
PHONE_ID=your_whatsapp_phone_id
WHATSAPP_TOKEN=your_whatsapp_system_user_token
VERIFY_TOKEN=your_custom_secure_webhook_token

# 5. Payments (Optional/Razorpay)
RAZORPAY_KEY_ID=your_razorpay_key_id
RAZORPAY_KEY_SECRET=your_razorpay_key_secret
